#!/usr/bin/env bash
set -euo pipefail

errors=0
root="$(cd "$(dirname "$0")/.." && pwd)"

if ! command -v python3 >/dev/null 2>&1; then
  echo "ERROR: python3 is required but not found"
  exit 1
fi

check_skill_symlinks() {
  while IFS= read -r entry; do
    name="$(basename "$entry")"
    link="$root/skills/$name"

    if [ ! -L "$link" ]; then
      echo "ERROR: skills/$name is not a symlink"
      errors=$((errors + 1))
    elif [ ! -e "$link" ]; then
      echo "ERROR: skills/$name is a broken symlink -> $(readlink "$link")"
      errors=$((errors + 1))
    else
      target="$(readlink "$link")"
      if [[ ! "$target" =~ ^\.\.\/plugins\/[^/]+\/skills\/[^/]+$ ]]; then
        echo "ERROR: skills/$name -> $target (must match ../plugins/{plugin}/skills/{name})"
        errors=$((errors + 1))
      elif [[ "$(basename "$target")" != "$name" ]]; then
        echo "ERROR: skills/$name -> $target (symlink name must match target directory name)"
        errors=$((errors + 1))
      fi
    fi
  done < <(find "$root/skills" -mindepth 1 -maxdepth 1)
}

check_command_symlinks() {
  while IFS= read -r entry; do
    name="$(basename "$entry")"
    link="$root/commands/$name"

    if [ ! -L "$link" ]; then
      echo "ERROR: commands/$name is not a symlink"
      errors=$((errors + 1))
    elif [ ! -e "$link" ]; then
      echo "ERROR: commands/$name is a broken symlink -> $(readlink "$link")"
      errors=$((errors + 1))
    else
      target="$(readlink "$link")"
      if [[ ! "$target" =~ ^\.\.\/plugins\/[^/]+\/commands\/[^/]+\.md$ ]]; then
        echo "ERROR: commands/$name -> $target (must match ../plugins/{plugin}/commands/{name}.md)"
        errors=$((errors + 1))
      elif [[ "$(basename "$target")" != "$name" ]]; then
        echo "ERROR: commands/$name -> $target (symlink name must match target file name)"
        errors=$((errors + 1))
      fi
    fi
  done < <(find "$root/commands" -mindepth 1 -maxdepth 1)
}

skill_names_from_manifest() {
  local manifest="$1"
  python3 - "$manifest" <<'PYEOF'
import json
import os
import sys

manifest = sys.argv[1]
with open(manifest) as f:
    data = json.load(f)

invalid = False
skills = data.get("skills", [])
if isinstance(skills, list):
    for path in skills:
        normalized = os.path.normpath(path)
        parts = normalized.split(os.sep)
        if len(parts) == 2 and parts[0] == "skills":
            print(parts[1])
        else:
            print(f"invalid skill path: {path}", file=sys.stderr)
            invalid = True
else:
    print("skills must be a list", file=sys.stderr)
    invalid = True

if invalid:
    sys.exit(1)
PYEOF
}

check_plugins() {
  for plugin_dir in "$root"/plugins/*/; do
    [ -d "$plugin_dir" ] || continue
    plugin="$(basename "$plugin_dir")"
    manifest="$plugin_dir/.claude-plugin/plugin.json"

    if [ ! -f "$manifest" ]; then
      echo "ERROR: plugins/$plugin is missing .claude-plugin/plugin.json"
      errors=$((errors + 1))
      continue
    fi

    skills_dir="$plugin_dir/skills"
    if [ ! -d "$skills_dir" ]; then
      echo "ERROR: plugins/$plugin is missing skills/ directory"
      errors=$((errors + 1))
      continue
    fi

    if ! skill_names="$(skill_names_from_manifest "$manifest")"; then
      echo "ERROR: plugins/$plugin plugin.json has invalid skill paths"
      errors=$((errors + 1))
      skill_names=""
    fi

    while IFS= read -r skill_dir; do
      name="$(basename "$skill_dir")"

      if [ -L "$skill_dir" ]; then
        echo "ERROR: plugins/$plugin/skills/$name is a symlink (must be real for plugin extraction)"
        errors=$((errors + 1))
        continue
      elif [ ! -d "$skill_dir" ]; then
        echo "ERROR: plugins/$plugin/skills/$name is not a directory"
        errors=$((errors + 1))
        continue
      fi

      link="$root/skills/$name"
      expected="../plugins/$plugin/skills/$name"
      if [ ! -L "$link" ]; then
        echo "ERROR: plugins/$plugin/skills/$name has no symlink in skills/"
        errors=$((errors + 1))
      elif [ "$(readlink "$link")" != "$expected" ]; then
        echo "ERROR: skills/$name -> $(readlink "$link") (expected $expected)"
        errors=$((errors + 1))
      fi

      if ! echo "$skill_names" | grep -Fqx -- "$name"; then
        echo "ERROR: plugins/$plugin/skills/$name exists but is not in plugin.json"
        errors=$((errors + 1))
      fi
    done < <(find "$skills_dir" -mindepth 1 -maxdepth 1)

    while IFS= read -r name; do
      [ -n "$name" ] || continue
      if [ ! -d "$plugin_dir/skills/$name" ]; then
        echo "ERROR: plugins/$plugin plugin.json references '$name' but plugins/$plugin/skills/$name/ does not exist"
        errors=$((errors + 1))
      fi
    done <<< "$skill_names"

    commands_dir="$plugin_dir/commands"
    if [ -d "$commands_dir" ]; then
      while IFS= read -r command_file; do
        name="$(basename "$command_file")"
        link="$root/commands/$name"
        expected="../plugins/$plugin/commands/$name"

        if [ ! -L "$link" ]; then
          echo "ERROR: plugins/$plugin/commands/$name has no symlink in commands/"
          errors=$((errors + 1))
        elif [ "$(readlink "$link")" != "$expected" ]; then
          echo "ERROR: commands/$name -> $(readlink "$link") (expected $expected)"
          errors=$((errors + 1))
        fi
      done < <(find "$commands_dir" -mindepth 1 -maxdepth 1 -name '*.md')
    fi
  done
}

check_marketplace() {
  local marketplace="$root/.claude-plugin/marketplace.json"
  [ -f "$marketplace" ] || return 0

  if ! python3 - "$marketplace" "$root" <<'PYEOF'
import json
import os
import sys

marketplace, root = sys.argv[1:3]
with open(marketplace) as f:
    data = json.load(f)

ok = True
for plugin in data.get("plugins", []):
    source = plugin.get("source")
    if not isinstance(source, str):
        print(f"marketplace plugin {plugin.get('name')} source must be a string", file=sys.stderr)
        ok = False
        continue
    path = os.path.normpath(os.path.join(root, source))
    manifest = os.path.join(path, ".claude-plugin", "plugin.json")
    if not os.path.isfile(manifest):
        print(f"marketplace source {source} has no .claude-plugin/plugin.json", file=sys.stderr)
        ok = False

sys.exit(0 if ok else 1)
PYEOF
  then
    echo "ERROR: marketplace references invalid plugin sources"
    errors=$((errors + 1))
  fi
}

check_skill_symlinks
check_command_symlinks
check_plugins
check_marketplace

if [ "$errors" -gt 0 ]; then
  echo ""
  echo "FAILED: $errors error(s) found"
  exit 1
fi

echo "OK: structure is valid"
